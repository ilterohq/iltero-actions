{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://iltero.io/schemas/config.schema.json",
  "title": "Iltero Stack Configuration",
  "description": "Configuration schema for Iltero infrastructure stacks",
  "type": "object",
  "required": ["stack", "environments"],
  "oneOf": [
    {
      "description": "Greenfield stack (managed, with infrastructure units)",
      "required": ["infrastructure_units"],
      "properties": {
        "infrastructure_units": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    {
      "description": "Brownfield stack (attached, with terraform_working_directory)",
      "not": {
        "required": ["infrastructure_units"]
      },
      "properties": {
        "stack": {
          "required": ["id", "name", "type", "terraform_working_directory"],
          "properties": {
            "type": {
              "const": "attached"
            },
            "terraform_working_directory": {
              "type": "string"
            }
          }
        }
      }
    }
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Config schema version",
      "default": "1.0.0"
    },
    "stack": {
      "type": "object",
      "description": "Stack identification",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique stack identifier (UUID)"
        },
        "name": {
          "type": "string",
          "description": "Human-readable stack name",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$"
        },
        "slug": {
          "type": "string",
          "description": "URL-friendly stack identifier",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "workspace": {
          "type": "string",
          "description": "Workspace this stack belongs to"
        },
        "description": {
          "type": "string",
          "description": "Stack description"
        },
        "type": {
          "type": "string",
          "description": "Stack type (managed or attached)",
          "enum": ["managed", "attached"]
        },
        "terraform_working_directory": {
          "type": "string",
          "description": "Terraform working directory (brownfield stacks)"
        }
      }
    },
    "bundle": {
      "type": "object",
      "description": "Policy bundle configuration",
      "properties": {
        "template_bundle_id": {
          "type": "string",
          "description": "Template bundle ID for policy resolution"
        }
      }
    },
    "terraform": {
      "type": "object",
      "description": "Terraform configuration",
      "properties": {
        "version": {
          "type": "string",
          "description": "Terraform version to use",
          "default": "latest"
        },
        "backend": {
          "type": "object",
          "description": "Backend configuration",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["s3", "gcs", "azurerm", "local", "remote"]
            }
          }
        }
      }
    },
    "infrastructure_units": {
      "type": "array",
      "description": "Infrastructure units in this stack",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Unit name (must be unique within stack)",
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$"
          },
          "path": {
            "type": "string",
            "description": "Path to unit directory relative to stack root"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether this unit is enabled",
            "default": true
          },
          "depends_on": {
            "type": "array",
            "description": "List of unit names this unit depends on",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "order": {
            "type": "integer",
            "description": "Explicit ordering (optional, dependencies take precedence)"
          },
          "description": {
            "type": "string",
            "description": "Unit description"
          }
        }
      },
      "minItems": 1
    },
    "environments": {
      "type": "object",
      "description": "Environment-specific configurations",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "git_ref": {
            "type": "object",
            "description": "Git reference that maps to this environment",
            "required": ["name"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["branch", "tag", "pattern"],
                "default": "branch",
                "description": "Type of git reference"
              },
              "name": {
                "type": "string",
                "description": "Branch/tag name or pattern"
              }
            }
          },
          "compliance": {
            "type": "object",
            "description": "Compliance scanning configuration",
            "properties": {
              "enabled": {
                "type": "boolean",
                "description": "Enable compliance scanning",
                "default": true
              },
              "scan_types": {
                "type": "array",
                "description": "Types of scans to run",
                "items": {
                  "type": "string",
                  "enum": ["static", "evaluation"]
                },
                "default": ["static"]
              },
              "block_on_violations": {
                "type": "boolean",
                "description": "Block deployment on compliance violations",
                "default": true
              },
              "frameworks": {
                "type": "array",
                "description": "Compliance frameworks to check",
                "items": {
                  "type": "string"
                }
              },
              "enforcement_mode": {
                "type": "string",
                "description": "Enforcement mode for compliance (brownfield stacks)",
                "enum": ["permissive", "enforcing"],
                "default": "permissive"
              },
              "policy_sets": {
                "type": "array",
                "description": "Policy set keys for compliance scanning (brownfield stacks)",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "monitoring": {
            "type": "object",
            "description": "Infrastructure monitoring configuration",
            "properties": {
              "enabled": {
                "type": "boolean",
                "description": "Enable infrastructure monitoring",
                "default": false
              },
              "alert_channels": {
                "type": "array",
                "description": "Alert notification channels",
                "items": {
                  "type": "string",
                  "enum": ["slack", "email", "pagerduty", "webhook"]
                },
                "default": []
              },
              "log_retention_days": {
                "type": "integer",
                "description": "Number of days to retain monitoring logs",
                "minimum": 1,
                "maximum": 365,
                "default": 30
              },
              "drift_detection": {
                "type": "object",
                "description": "Configuration drift detection settings",
                "properties": {
                  "enabled": {
                    "type": "boolean",
                    "description": "Enable drift detection",
                    "default": false
                  },
                  "schedule": {
                    "type": "string",
                    "description": "Cron schedule for drift checks (e.g., '0 */4 * * *')",
                    "pattern": "^([0-9*,/-]+\\s+){4}[0-9*,/-]+$"
                  },
                  "auto_remediate": {
                    "type": "boolean",
                    "description": "Automatically remediate detected drift",
                    "default": false
                  }
                }
              },
              "compliance_monitoring": {
                "type": "object",
                "description": "Runtime compliance monitoring settings",
                "properties": {
                  "real_time": {
                    "type": "boolean",
                    "description": "Enable real-time compliance monitoring",
                    "default": false
                  },
                  "alert_on_violations": {
                    "type": "boolean",
                    "description": "Send alerts when violations are detected",
                    "default": true
                  }
                }
              }
            }
          },
          "security": {
            "type": "object",
            "description": "Security configuration",
            "properties": {
              "severity_threshold": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"],
                "description": "Minimum severity level to fail on",
                "default": "high"
              }
            }
          },
          "deployment": {
            "type": "object",
            "description": "Deployment configuration",
            "properties": {
              "require_approval": {
                "type": "boolean",
                "description": "Require manual approval before deployment",
                "default": false
              },
              "auto_apply_on_merge": {
                "type": "boolean",
                "description": "Automatically apply on merge to branch",
                "default": false
              },
              "approval": {
                "type": "object",
                "description": "Approval configuration (when require_approval is true)",
                "properties": {
                  "required_approvers": {
                    "type": "integer",
                    "minimum": 1,
                    "default": 1
                  },
                  "approval_groups": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "variables": {
            "type": "object",
            "description": "Environment-specific variables",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
